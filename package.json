  "description": "Native Trello tools for OpenClaw — list boards, create/move cards, add comments, manage checklists.",
  "type": "module",
  "homepage": "https://github.com/marcchapeau/openclaw-trello",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcchapeau/openclaw-trello.git"
  },
  "license": "MIT",
  "keywords": [
    "openclaw",
    "trello",
    "plugin"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": "2026.3.28"
    },
    "build": {
      "openclawVersion": "2026.3.28"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  }
